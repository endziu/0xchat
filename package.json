{
  "name": "eth-chat",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clear:db": "rm -f chat.db chat.db-shm chat.db-wal && echo 'DB cleared'",
    "clear:dist": "rm -rf dist && echo 'Dist cleared'",
    "clear": "bun clear:db; bun clear:dist",
    "build": "vite build",
    "dev": "concurrently 'bun run server.ts' 'vite'",
    "dev:debug": "DEBUG=1 concurrently 'bun run server.ts' 'vite'",
    "start": "bun clear; bun run build; bun run server.ts",
    "start:prod": "bun run server.ts",
    "start:debug": "DEBUG=1 bun start",
    "test": "bun run build && bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src server.ts"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@noble/secp256k1": "3.0.0",
    "clsx": "^2.1.1",
    "lucide-preact": "^0.474.0",
    "preact": "^10.29.0",
    "tailwind-merge": "^3.5.0",
    "viem": "2.47.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.9.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "1.3.10",
    "concurrently": "9.2.1",
    "oxlint": "0.16.6",
    "tailwindcss": "^4.2.2",
    "typescript": "5.6.3",
    "vite": "5.4.14"
  }
}
