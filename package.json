{
  "name": "eth-chat",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src server.ts --ignore-pattern \"src/server/secp256k1.bundle.js\" --ignore-pattern \"src/server/wallet.bundle.js\"",
    "test": "bun test",
    "server": "bun run server.ts",
    "build:crypto": "bun build --bundle --format esm --minify --outfile src/server/secp256k1.bundle.js src/crypto-entry.ts",
    "build:wallet": "bun build --bundle --format esm --minify --outfile src/server/wallet.bundle.js src/wallet-entry.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "oxlint": "0.16.6",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "4.3.7",
    "@metamask/sdk": "0.34.0",
    "@noble/secp256k1": "3.0.0",
    "@reown/appkit": "1.8.19",
    "@reown/appkit-adapter-wagmi": "1.8.19",
    "@wagmi/core": "3.4.0",
    "@walletconnect/ethereum-provider": "2.23.8",
    "porto": "0.2.37",
    "viem": "2.47.4"
  }
}
